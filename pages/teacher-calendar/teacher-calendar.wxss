/* 月份选择 */
.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--surface);
}

.month-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}

.month-btn text {
  font-size: 40rpx;
  color: var(--primary);
}

.month-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 每周视图 - 每天一列 */
.week-view {
  background: var(--surface);
  margin-bottom: 20rpx;
}

.week-header {
  display: flex;
  border-bottom: 1rpx solid var(--border);
}

.week-day-header {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.days-scroll {
  width: 100%;
  white-space: nowrap;
}

.days-container {
  display: inline-flex;
  padding: 20rpx 10rpx;
}

.day-column {
  width: 120rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin: 0 10rpx;
  padding: 20rpx 10rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
  transition: all 0.2s;
}

.day-column.today {
  background: rgba(123, 104, 238, 0.1);
  border: 2rpx solid var(--primary);
}

.day-column.has-booking {
  background: rgba(82, 196, 26, 0.1);
}

.day-column:active {
  transform: scale(0.95);
}

.day-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
}

.day-week {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.day-number {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.day-column.today .day-number {
  color: var(--primary);
}

.day-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
}

.booking-count {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.count-num {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--success);
}

.count-text {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.no-booking {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 图例 */
.legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 20rpx;
  background: var(--surface);
  margin-bottom: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-dot.has-booking {
  background: var(--success);
}

.legend-dot.today-dot {
  background: var(--primary);
}

/* 底部详情 */
.day-detail {
  background: var(--surface);
  border-radius: 16rpx;
  padding: 30rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.detail-date {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.detail-tip {
  font-size: 24rpx;
  color: var(--text-hint);
}

.detail-section {
  margin-bottom: 30rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.add-btn {
  color: var(--primary);
  font-size: 26rpx;
}

/* 约课列表 */
.booking-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.booking-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
}

.booking-info {
  display: flex;
  flex-direction: column;
}

.student-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.booking-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.booking-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.booking-status.pending {
  background: rgba(250, 173, 20, 0.1);
  color: var(--warning);
}

.booking-status.accepted {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success);
}

/* 时间列表 */
.time-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.time-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
}

.time-range {
  font-size: 26rpx;
  color: var(--text-primary);
}

.delete-btn {
  font-size: 24rpx;
  color: var(--error);
}

.empty-tip {
  text-align: center;
  padding: 30rpx;
  color: var(--text-hint);
  font-size: 26rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 600rpx;
  background: var(--surface);
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.form-item .label {
  width: 140rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.picker-value {
  flex: 1;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 20rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: var(--text-secondary);
}

.btn-confirm {
  background: var(--primary);
  color: #fff;
}
