/**pages/courses/courses.wxss**/
.date-selector {
  background: var(--surface);
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.date-scroll {
  white-space: nowrap;
}

.date-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 120rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}

.date-item:last-child {
  margin-right: 20rpx;
}

.date-item.active {
  background: var(--primary);
}

.date-item .day {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.date-item.active .day,
.date-item.active .week {
  color: #fff;
}

.date-item .week {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 课程卡片 */
.course-card {
  background: var(--surface);
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.course-header {
  position: relative;
  height: 300rpx;
}

.course-cover {
  width: 100%;
  height: 100%;
}

.course-badges {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  display: flex;
  gap: 12rpx;
}

.badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #fff;
}

.badge.level-1 {
  background: #52c41a;
}

.badge.level-2 {
  background: #faad14;
}

.badge.level-3 {
  background: #ff4d4f;
}

.badge.style {
  background: rgba(123, 104, 238, 0.9);
}

.course-body {
  padding: 24rpx;
}

.course-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.course-info {
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 26rpx;
  margin-right: 12rpx;
}

.info-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.course-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.capacity {
  flex: 1;
  margin-right: 20rpx;
}

.capacity progress {
  margin-bottom: 8rpx;
}

.capacity-text {
  font-size: 22rpx;
  color: var(--text-hint);
}

.course-price .price {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--secondary);
}

.load-more {
  text-align: center;
  padding: 40rpx;
  color: var(--text-hint);
  font-size: 24rpx;
}
