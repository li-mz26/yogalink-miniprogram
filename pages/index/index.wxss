/**pages/index/index.wxss**/
/* 老师端样式 */
.hero-section.teacher {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
}

.quick-actions {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: var(--surface);
  border-radius: 16rpx;
  margin-right: 16rpx;
}

.action-item:last-child {
  margin-right: 0;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.action-icon.badge {
  position: relative;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-primary);
}

/* 预约请求卡片 */
.request-card {
  background: var(--surface);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.request-card.pending {
  border-left: 6rpx solid var(--warning);
}

.request-card.accepted {
  border-left: 6rpx solid var(--success);
}

.request-card.rejected,
.request-card.cancelled {
  border-left: 6rpx solid #ccc;
}

.request-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 16rpx;
}

.student-info {
  flex: 1;
}

.student-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}

.request-time {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.status-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.status-tag.pending {
  background: rgba(250, 173, 20, 0.1);
  color: var(--warning);
}

.status-tag.accepted {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success);
}

.request-location {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.request-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.btn-reject {
  background: #f5f5f5;
  color: #999;
  border: none;
}

.btn-accept {
  background: var(--success);
  color: #fff;
  border: none;
}

.location-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.location-tag {
  padding: 12rpx 20rpx;
  background: rgba(123, 104, 238, 0.1);
  color: var(--primary);
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 学生端样式 */
.search-section {
  margin-bottom: 30rpx;
}

.search-input {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-text {
  font-size: 30rpx;
  color: var(--text-primary);
}

.search-text.placeholder {
  color: var(--text-hint);
}

.search-filters {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.filter-item {
  display: flex;
  align-items: center;
}

.filter-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-right: 12rpx;
}

.filter-value {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 500;
}

.btn-search {
  padding: 16rpx 40rpx;
  background: var(--primary);
  color: #fff;
  font-size: 28rpx;
  border-radius: 32rpx;
  border: none;
}

.btn-search[disabled] {
  background: #e0e0e0;
  color: #999;
}

/* 老师卡片 */
.teacher-list {
  margin-bottom: 30rpx;
}

.teacher-card {
  display: flex;
  background: var(--surface);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.teacher-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  background: #f5f5f5;
}

.teacher-info {
  flex: 1;
  min-width: 0;
}

.teacher-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.teacher-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.teacher-rating {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-hint);
}

.teacher-bio {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.teacher-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.teacher-tags .tag {
  padding: 4rpx 12rpx;
  background: rgba(123, 104, 238, 0.1);
  color: var(--primary);
  border-radius: 6rpx;
  font-size: 22rpx;
}

.teacher-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.teacher-distance {
  font-size: 24rpx;
  color: var(--text-hint);
}

.teacher-price {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--secondary);
}

/* 我的预约 */
.booking-item {
  display: flex;
  align-items: center;
  background: var(--surface);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.booking-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
}

.booking-info {
  flex: 1;
  min-width: 0;
}

.booking-teacher {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.booking-time,
.booking-location {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.booking-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}
