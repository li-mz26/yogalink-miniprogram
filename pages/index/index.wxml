/**pages/index/index.wxml**/
<view class="container">
  <!-- 未登录 -->
  <view class="login-tip card" wx:if="{{!isLogin}}">
    <text class="tip-text">登录后即可使用</text>
    <button class="btn btn-primary" bindtap="goToLogin">立即登录</button>
  </view>

  <!-- 老师端首页 -->
  <block wx:elif="{{userInfo.role === 'teacher'}}">
    <include src="./teacher_home.wxml"/>
  </block>

  <!-- 学生端首页 -->
  <block wx:else>
    <include src="./student_home.wxml"/>
  </block>
</view>
