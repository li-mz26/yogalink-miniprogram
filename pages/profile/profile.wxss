/**pages/profile/profile.wxss**/
.profile-card {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 未登录 */
.login-prompt {
  display: flex;
  align-items: center;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  margin-right: 30rpx;
}

.login-text {
  flex: 1;
}

.prompt {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.btn-login {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 26rpx;
  border-radius: 30rpx;
  border: none;
}

.btn-login::after {
  border: none;
}

/* 实名认证卡片 */
.verify-card {
  display: flex;
  align-items: center;
  background: var(--surface);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.verify-card.verified {
  background: rgba(82, 196, 26, 0.1);
  border: 1rpx solid rgba(82, 196, 26, 0.3);
}

.verify-card.pending {
  background: rgba(250, 173, 20, 0.1);
  border: 1rpx solid rgba(250, 173, 20, 0.3);
}

.verify-card.rejected {
  background: rgba(255, 77, 79, 0.1);
  border: 1rpx solid rgba(255, 77, 79, 0.3);
}

.verify-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.verify-info {
  flex: 1;
}

.verify-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.verify-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: var(--surface);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid var(--border);
}

.stat-item:last-child {
  border-right: none;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 菜单列表 */
.menu-list {
  margin-bottom: 40rpx;
}

.menu-group {
  background: var(--surface);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  position: relative;
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.logout .menu-text {
  color: var(--error);
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--text-hint);
}

.contact-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
}

/* 版本信息 */
.version {
  text-align: center;
  padding: 40rpx;
}

.version text {
  font-size: 24rpx;
  color: var(--text-hint);
}
