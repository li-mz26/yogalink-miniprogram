/**pages/login/login.wxss**/
page {
  background: linear-gradient(180deg, #7B68EE 0%, #9B8AF0 50%, #f5f5f5 100%);
  min-height: 100vh;
}

.container {
  padding: 60rpx 50rpx;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  backdrop-filter: blur(10rpx);
}

.logo-placeholder text {
  font-size: 80rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 登录表单 */
.login-form {
  background: var(--surface);
  border-radius: 24rpx;
  padding: 50rpx;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.input-group {
  margin-bottom: 40rpx;
}

.input-group:last-of-type {
  margin-bottom: 50rpx;
}

.input-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.input {
  height: 96rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.password-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.password-wrap .input {
  flex: 1;
}

.eye-icon {
  position: absolute;
  right: 30rpx;
  font-size: 36rpx;
  padding: 20rpx;
}

/* 按钮 */
.btn-login {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  margin-bottom: 30rpx;
  border: none;
}

.btn-login::after {
  border: none;
}

.btn-login.disabled {
  background: #e0e0e0;
  color: #999;
}

.btn-register {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: transparent;
  color: var(--primary);
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: 2rpx solid var(--primary);
}

.btn-register::after {
  border: none;
}

.btn-register.disabled {
  color: #999;
  border-color: #e0e0e0;
}

/* 提示信息 */
.tips {
  text-align: center;
  margin-top: 50rpx;
}

.tips text {
  font-size: 26rpx;
  color: var(--text-hint);
}
