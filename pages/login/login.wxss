/**pages/login/login.wxss**/
page {
  background: linear-gradient(180deg, #7B68EE 0%, #9B8AF0 50%, #f5f5f5 100%);
  min-height: 100vh;
}

.container {
  padding: 40rpx 50rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.logo-placeholder {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.logo-placeholder text {
  font-size: 60rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
}

.app-slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 角色选择 */
.role-selector {
  display: flex;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.role-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  transition: all 0.3s;
}

.role-option.active {
  background: rgba(255, 255, 255, 0.3);
  border-color: #fff;
}

.role-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.role-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* 登录表单 */
.login-form {
  background: var(--surface);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.input-group {
  margin-bottom: 30rpx;
}

.input-group:last-of-type {
  margin-bottom: 40rpx;
}

.input-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.input {
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.password-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.password-wrap .input {
  flex: 1;
}

.eye-icon {
  position: absolute;
  right: 24rpx;
  font-size: 32rpx;
  padding: 16rpx;
}

/* 按钮 */
.btn-login {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  margin-bottom: 24rpx;
  border: none;
}

.btn-login::after {
  border: none;
}

.btn-login.disabled {
  background: #e0e0e0;
  color: #999;
}

.btn-register {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: transparent;
  color: var(--primary);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: 2rpx solid var(--primary);
}

.btn-register::after {
  border: none;
}

.btn-register.disabled {
  color: #999;
  border-color: #e0e0e0;
}

.tips {
  text-align: center;
  margin-top: 40rpx;
}

.tips text {
  font-size: 24rpx;
  color: var(--text-hint);
}
