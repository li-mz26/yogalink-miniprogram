/**pages/bookings/bookings.wxml**/
<view class="container">
  <!-- 登录提示 -->
  <view class="login-tip card" wx:if="{{!isLogin}}">
    <text class="tip-text">登录后查看您的预约</text>
    <button class="btn btn-primary" bindtap="goToLogin">立即登录</button>
  </view>

  <!-- 预约列表 -->
  <view wx:elif="{{bookings.length > 0}}">
    <!-- 筛选标签 -->
    <view class="filter-tabs">
      <view 
        class="tab {{activeTab === 'all' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="all"
      >
        全部
      </view>
      
      <view 
        class="tab {{activeTab === 'upcoming' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="upcoming"
      >
        即将开始
      </view>
      
      <view 
        class="tab {{activeTab === 'completed' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="completed"
      >
        已完成
      </view>
    </view>
    
    <!-- 列表 -->
    <view class="booking-list">
      <view 
        class="booking-card {{item.status === 0 ? 'cancelled' : ''}}"
        wx:for="{{filteredBookings}}"
        wx:key="id"
      >
        <view class="booking-header">
          <view class="booking-no">订单号: {{item.booking_no}}</view>
          <view class="status-badge status-{{item.status}}">
            {{statusMap[item.status].text}}
          </view>
        </view>
        
        <view class="booking-body">
          <view class="course-info">
            <text class="course-name">{{item.schedule.template.name}}</text>
            
            <view class="course-meta">
              <text class="tag">{{item.schedule.template.style}}</text>
              <text class="level level-{{item.schedule.template.level}}">
                {{item.schedule.template.level === 1 ? '初级' : item.schedule.template.level === 2 ? '中级' : '高级'}}
              </text>
            </view>
          </view>
          
          <view class="schedule-info">
            <view class="info-row">
              <text class="icon">🕐</text>
              <text class="text">{{item.schedule.course_date}} {{item.schedule.start_time}}</text>
            </view>
            
            <view class="info-row">
              <text class="icon">👤</text>
              <text class="text">{{item.schedule.instructor.name}}</text>
            </view>
            
            <view class="info-row">
              <text class="icon">📍</text>
              <text class="text">{{item.schedule.studio.name}}</text>
            </view>
          </view>
          
          <view class="booking-footer">
            <text class="booking-price">¥{{item.price}}</text>
            
            <view class="actions" wx:if="{{item.status === 2}}">
              <!-- 待上课时显示签到码 -->
              <view class="checkin-code" wx:if="{{item.checkin_code}}">
                签到码: {{item.checkin_code}}
              </view>
              
              <button 
                class="btn-cancel" 
                size="mini"
                bindtap="cancelBooking"
                data-id="{{item.id}}"
              >
                取消预约
              </button>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading}}">
    <text class="empty-text">暂无预约记录</text>
    <button class="btn btn-secondary" bindtap="goToCourses">去预约课程</button>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
