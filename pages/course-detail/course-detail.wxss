/**pages/course-detail/course-detail.wxss**/
.course-hero {
  position: relative;
  height: 400rpx;
  margin: -30rpx -30rpx 30rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
}

.hero-badges {
  display: flex;
  gap: 16rpx;
}

.hero-badges .badge {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #fff;
}

.hero-badges .badge.level-1 {
  background: #52c41a;
}

.hero-badges .badge.level-2 {
  background: #faad14;
}

.hero-badges .badge.level-3 {
  background: #ff4d4f;
}

.hero-badges .badge.style {
  background: rgba(255,255,255,0.3);
  backdrop-filter: blur(10rpx);
}

/* 课程信息 */
.info-section .course-name {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 30rpx;
}

.info-list {
  border-top: 1rpx solid var(--border);
  padding-top: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.info-value.price {
  color: var(--secondary);
  font-size: 32rpx;
}

/* 教练信息 */
.instructor-section .section-title,
.desc-section .section-title,
.booking-section .section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 24rpx;
}

.instructor-info {
  display: flex;
  align-items: flex-start;
}

.instructor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  background: #f5f5f5;
}

.instructor-detail {
  flex: 1;
}

.instructor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}

.instructor-bio {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.instructor-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.instructor-tags .tag {
  padding: 6rpx 16rpx;
  background: rgba(123, 104, 238, 0.1);
  color: var(--primary);
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 课程介绍 */
.course-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 预约状态 */
.booking-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.booking-count {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.booking-status {
  text-align: center;
  margin-top: 20rpx;
}

.status-text {
  font-size: 26rpx;
}

.status-text.full {
  color: var(--error);
}

.status-text.warning {
  color: var(--warning);
}

.status-text.normal {
  color: var(--success);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: var(--surface);
  border-top: 1rpx solid var(--border);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.price-section {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.price-label {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 4rpx;
}

.price-value {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--secondary);
}

.btn-book {
  width: 280rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  text-align: center;
}

.btn-book.disabled {
  background: #e0e0e0;
  color: #999;
}

/* 加载中 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}
