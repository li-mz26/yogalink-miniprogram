/**app.wxss**/
page {
  --primary: #7B68EE;
  --primary-light: #9B8AF0;
  --primary-dark: #5A4ACF;
  --secondary: #FF6B9D;
  --background: #f5f5f5;
  --surface: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border: #e0e0e0;
  --success: #52c41a;
  --warning: #faad14;
  --error: #ff4d4f;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: var(--background);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.5;
}

/* 通用容器 */
.container {
  padding: 30rpx;
}

/* 卡片样式 */
.card {
  background: var(--surface);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background: var(--surface);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-secondary:active {
  background: rgba(123, 104, 238, 0.1);
}

.btn-disabled {
  background: #e0e0e0;
  color: #999;
}

/* 文本样式 */
.text-primary {
  color: var(--primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-hint {
  color: var(--text-hint);
  font-size: 24rpx;
}

.text-center {
  text-align: center;
}

.text-bold {
  font-weight: 600;
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-primary {
  background: rgba(123, 104, 238, 0.1);
  color: var(--primary);
}

.tag-success {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success);
}

.tag-warning {
  background: rgba(250, 173, 20, 0.1);
  color: var(--warning);
}

/* 列表样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: var(--surface);
  border-bottom: 1rpx solid var(--border);
}

.list-item:last-child {
  border-bottom: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  color: var(--text-hint);
  font-size: 28rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-text {
  margin-left: 16rpx;
  color: var(--text-hint);
  font-size: 26rpx;
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
